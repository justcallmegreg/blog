---
// First-visit Vault door intro: a Fallout-style gear door that unscrews and
// rolls away, revealing the site. Decided server-side from the
// `gregco-vault-door` cookie so repeat visits render nothing (no flash). The
// cookie is written client-side when the animation actually plays — and, when
// the consent gate is on screen, only after the visitor accepts, so the gate
// stays the first (and only pre-consent) cookie decision.
import { getConfig } from '../lib/config';

const cfg = getConfig();
const seen = Astro.cookies.get('gregco-vault-door')?.value === '1';
const show = !seen;
const vault = String(cfg.effects.vaultDoorNumber);
const title = cfg.site.title;
---
{show && (
  <div id="vault-intro" data-vault={vault} data-title={title} aria-hidden="true">
    <div class="vi-wall"></div>
    <div class="vi-rail"></div>
    <div class="vi-flood"></div>
    <div class="vi-opening"></div>
    <div class="vi-frame"></div>
    <div class="vi-interior">
      <div class="vi-glyph">▚▚▚ VAULT-TEC ▞▞▞</div>
      <p class="vi-title">VAULT&nbsp;{vault}</p>
      <p class="vi-sub">{title}</p>
      <p class="vi-copy" id="vi-copyright"></p>
    </div>
    <div class="vi-track" id="vi-track">
      <div class="vi-spin" id="vi-spin">
        <svg class="vi-door" id="vi-door" viewBox="0 0 600 600" aria-hidden="true"></svg>
      </div>
    </div>
    <div class="vi-steam"><i></i><i></i><i></i><i></i><i></i></div>
    <div class="vi-debris"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
    <div class="vi-dust"><i></i><i></i><i></i><i></i></div>
    <div class="vi-lamp"></div>
    <div class="vi-wash"></div>
    <div class="vi-hud">
      <span class="vi-status" id="vi-status">STANDBY</span>
      <a class="vi-skip" id="vi-skip" href="#">[ SKIP &gt;&gt; ]</a>
    </div>
    <div class="vi-boot" id="vi-boot"></div>
    <div class="vi-crt"></div>
  </div>
)}
<style>
  #vault-intro {
    /* below the consent gate (1000), above everything else incl. body scanlines */
    position: fixed; inset: 0; z-index: 900;
    background: #050705;
    font-family: var(--font);
    --D: min(78vmin, 660px);
    transition: opacity 0.9s ease;
  }
  #vault-intro.vi-leave { opacity: 0; pointer-events: none; }

  .vi-wall {
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 50% 42%, rgba(120,130,118,0.20) 0%, rgba(28,32,28,0.9) 46%, #05070522 70%),
      radial-gradient(circle at 50% 42%, transparent calc(var(--D) * 0.55), rgba(0,0,0,0.75) calc(var(--D) * 0.56)),
      linear-gradient(180deg, #131713 0%, #0a0d0a 55%, #060806 100%);
  }
  .vi-wall::before {
    content: ''; position: absolute; inset: 0; opacity: 0.5; mix-blend-mode: overlay;
    background-image:
      repeating-radial-gradient(circle at 21% 33%, rgba(255,255,255,0.03) 0 1px, transparent 1px 5px),
      repeating-radial-gradient(circle at 77% 61%, rgba(0,0,0,0.28) 0 2px, transparent 2px 7px),
      repeating-linear-gradient(97deg, rgba(255,255,255,0.02) 0 1px, transparent 1px 6px);
  }
  .vi-wall::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 45% at 50% -4%, rgba(190,220,190,0.10), transparent 60%);
  }

  .vi-rail {
    position: absolute; left: 4%; right: 30%;
    top: calc(50% - var(--D) * 0.62);
    height: calc(var(--D) * 0.045);
    background: linear-gradient(180deg, #3c423c, #161a16 60%, #2a2f2a);
    border: 1px solid #000;
    box-shadow: 0 4px 14px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.12);
  }
  .vi-rail::after {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(90deg, transparent 0 44px, rgba(0,0,0,0.55) 44px 48px);
  }

  .vi-opening {
    position: absolute; left: 50%; top: 50%;
    width: var(--D); height: var(--D);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: #010201;
    box-shadow: inset 0 0 60px 22px #000;
  }
  .vi-flood {
    position: absolute; left: 50%; top: 50%;
    width: var(--D); height: var(--D);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(circle, rgba(120,255,160,0.30), transparent 65%);
    filter: blur(6px);
    z-index: 3;
  }
  #vault-intro.vi-rolling .vi-flood { opacity: 1; transition: opacity 1.6s ease 0.3s; }
  #vault-intro.vi-revealed .vi-flood { opacity: 0.25; }

  .vi-frame {
    position: absolute; left: 50%; top: 50%;
    width: calc(var(--D) * 1.12); height: calc(var(--D) * 1.12);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    pointer-events: none;
    z-index: 2;
    background:
      radial-gradient(circle,
        transparent calc(50% - var(--D) * 0.062),
        #3a413a calc(50% - var(--D) * 0.058),
        #171b17 calc(50% - var(--D) * 0.028),
        #2d332d calc(50% - var(--D) * 0.004),
        transparent 50%);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.6);
  }

  /* Reveal text sits above every graphic layer so nothing can crop it. */
  .vi-interior {
    position: absolute; left: 50%; top: 50%;
    width: var(--D); height: var(--D);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    z-index: 8;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.4rem; text-align: center;
    background:
      radial-gradient(circle at 50% 58%, rgba(51,255,102,0.20), rgba(6,20,9,0.95) 62%),
      #041007;
    opacity: 0; transition: opacity 1.2s ease;
    pointer-events: none;
  }
  #vault-intro.vi-revealed .vi-interior { opacity: 1; }
  .vi-glyph { font-size: calc(var(--D) * 0.05); color: var(--fg-dim); letter-spacing: 0.4em; }
  .vi-title {
    margin: 0;
    font-size: calc(var(--D) * 0.11);
    color: var(--accent);
    text-shadow: 0 0 18px rgba(182,255,0,0.5);
    letter-spacing: 0.06em;
    line-height: 1.1;
  }
  .vi-sub { margin: 0; color: var(--fg); font-size: calc(var(--D) * 0.036); max-width: 70%; }
  .vi-copy { margin: 0; color: var(--fg-dim); font-size: calc(var(--D) * 0.032); }

  .vi-track {
    position: absolute; left: 50%; top: 50%;
    width: var(--D); height: var(--D);
    margin: calc(var(--D) / -2) 0 0 calc(var(--D) / -2);
    z-index: 4;
    transition: transform 2s cubic-bezier(0.65, 0, 0.35, 1);
  }
  #vault-intro.vi-rolling .vi-track { transform: translateX(calc(var(--D) * -1.28)); }
  .vi-spin {
    width: 100%; height: 100%;
    transition: transform 2.2s cubic-bezier(0.4, 0.1, 0.3, 1), scale 2.2s ease;
    filter: drop-shadow(0 calc(var(--D)*0.02) calc(var(--D)*0.04) rgba(0,0,0,0.85));
  }
  #vault-intro.vi-unsealing .vi-spin { transform: rotate(-380deg); scale: 1.055; }
  #vault-intro.vi-rolling .vi-spin {
    transform: rotate(-540deg); scale: 1.055;
    transition: transform 2s cubic-bezier(0.65, 0, 0.35, 1);
  }
  #vault-intro.vi-shudder .vi-spin { animation: vi-shudder 0.45s steps(2, jump-none) 2; }
  @keyframes vi-shudder {
    0%,100% { translate: 0 0; }
    25% { translate: calc(var(--D) * -0.004) calc(var(--D) * 0.003); }
    75% { translate: calc(var(--D) * 0.004) calc(var(--D) * -0.004); }
  }
  .vi-door { width: 100%; height: 100%; display: block; }

  .vi-steam { position: absolute; left: 50%; top: 50%; z-index: 5; pointer-events: none; }
  .vi-steam i {
    position: absolute; display: block;
    width: calc(var(--D) * 0.3); height: calc(var(--D) * 0.3);
    margin: calc(var(--D) * -0.15);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(210,225,210,0.5), transparent 70%);
    filter: blur(8px);
    opacity: 0; scale: 0.2;
  }
  #vault-intro.vi-unsealing .vi-steam i, #vault-intro.vi-rolling .vi-steam i {
    animation: vi-puff 1.8s ease-out forwards;
  }
  .vi-steam i:nth-child(1) { --a: 205deg; animation-delay: 0.05s !important; }
  .vi-steam i:nth-child(2) { --a: 335deg; animation-delay: 0.2s !important; }
  .vi-steam i:nth-child(3) { --a: 90deg;  animation-delay: 0.35s !important; }
  .vi-steam i:nth-child(4) { --a: 250deg; animation-delay: 0.65s !important; }
  .vi-steam i:nth-child(5) { --a: 25deg;  animation-delay: 0.9s !important; }
  @keyframes vi-puff {
    0%   { opacity: 0; scale: 0.2; transform: rotate(var(--a)) translateY(calc(var(--D) * -0.46)); }
    18%  { opacity: 0.85; }
    100% { opacity: 0; scale: 1.7; transform: rotate(var(--a)) translateY(calc(var(--D) * -0.62)); }
  }

  .vi-debris { position: absolute; left: 50%; top: 50%; z-index: 6; pointer-events: none; }
  .vi-debris i {
    position: absolute;
    width: calc(var(--D) * 0.013); height: calc(var(--D) * 0.011);
    background: #5c6157; opacity: 0;
  }
  #vault-intro.vi-shudder .vi-debris i,
  #vault-intro.vi-unsealing .vi-debris i,
  #vault-intro.vi-rolling .vi-debris i {
    animation: vi-debrisfall 1.3s cubic-bezier(0.3, 0, 0.8, 0.4) forwards;
    animation-delay: var(--wait);
  }
  .vi-debris i:nth-child(1) { --dx: -0.38; --drift: -0.03; --wait: 0.00s; scale: 0.8; background: #6b7060; }
  .vi-debris i:nth-child(2) { --dx: -0.16; --drift:  0.02; --wait: 0.12s; }
  .vi-debris i:nth-child(3) { --dx:  0.05; --drift: -0.02; --wait: 0.05s; scale: 1.3; background: #4a4e44; }
  .vi-debris i:nth-child(4) { --dx:  0.24; --drift:  0.04; --wait: 0.22s; scale: 0.7; }
  .vi-debris i:nth-child(5) { --dx:  0.40; --drift: -0.01; --wait: 0.34s; }
  .vi-debris i:nth-child(6) { --dx: -0.28; --drift:  0.03; --wait: 0.85s; scale: 1.2; background: #6b7060; }
  .vi-debris i:nth-child(7) { --dx:  0.12; --drift: -0.04; --wait: 1.05s; scale: 0.9; }
  .vi-debris i:nth-child(8) { --dx: -0.02; --drift:  0.02; --wait: 1.30s; }
  @keyframes vi-debrisfall {
    0%   { opacity: 0; transform: translate(calc(var(--D) * var(--dx)), calc(var(--D) * -0.54)) rotate(0deg); }
    10%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { opacity: 0; transform: translate(calc(var(--D) * (var(--dx) + var(--drift))), calc(var(--D) * 0.18)) rotate(230deg); }
  }

  .vi-dust { position: absolute; left: 50%; top: 50%; z-index: 5; pointer-events: none; }
  .vi-dust i {
    position: absolute;
    width: calc(var(--D) * 0.22); height: calc(var(--D) * 0.14);
    margin: calc(var(--D) * -0.07) calc(var(--D) * -0.11);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(128,120,100,0.4), transparent 70%);
    filter: blur(7px);
    opacity: 0;
  }
  #vault-intro.vi-rolling .vi-dust i { animation: vi-dustkick 1.4s ease-out forwards; animation-delay: var(--wait); }
  .vi-dust i:nth-child(1) { --dx: -0.15; --wait: 0.10s; }
  .vi-dust i:nth-child(2) { --dx: -0.45; --wait: 0.35s; }
  .vi-dust i:nth-child(3) { --dx: -0.75; --wait: 0.60s; }
  .vi-dust i:nth-child(4) { --dx: -1.05; --wait: 0.85s; }
  @keyframes vi-dustkick {
    0%   { opacity: 0; scale: 0.3; transform: translate(calc(var(--D) * var(--dx)), calc(var(--D) * 0.44)); }
    25%  { opacity: 0.55; }
    100% { opacity: 0; scale: 1.8; transform: translate(calc(var(--D) * (var(--dx) - 0.08)), calc(var(--D) * 0.36)); }
  }

  .vi-lamp {
    position: absolute; left: 50%; top: calc(50% - var(--D) * 0.78);
    width: calc(var(--D) * 0.075); height: calc(var(--D) * 0.055);
    transform: translateX(-50%);
    background: radial-gradient(circle at 50% 30%, #7a1410, #2a0503 70%);
    border-radius: 45% 45% 12% 12%;
    border: 1px solid #000;
    z-index: 6;
  }
  .vi-lamp::after {
    content: ''; position: absolute; left: 50%; top: 60%;
    width: calc(var(--D) * 2.6); height: calc(var(--D) * 0.5);
    margin: calc(var(--D) * -0.25) 0 0 calc(var(--D) * -1.3);
    background: conic-gradient(from 0deg,
      transparent 0 20deg, rgba(255,60,45,0.28) 30deg 45deg, transparent 55deg 180deg,
      rgba(255,60,45,0.28) 205deg 225deg, transparent 235deg);
    border-radius: 50%;
    opacity: 0; filter: blur(2px);
  }
  #vault-intro.vi-alarm .vi-lamp {
    background: radial-gradient(circle at 50% 30%, #ff4538, #6b0d06 70%);
    box-shadow: 0 0 26px 6px rgba(255,59,47,0.55);
  }
  #vault-intro.vi-alarm .vi-lamp::after { opacity: 1; animation: vi-beam 1.1s linear infinite; }
  @keyframes vi-beam { to { transform: rotate(360deg); } }
  .vi-wash { position: absolute; inset: 0; z-index: 7; pointer-events: none; opacity: 0; background: rgba(255,40,25,0.07); }
  #vault-intro.vi-alarm .vi-wash { animation: vi-wash 1.1s ease-in-out infinite; }
  @keyframes vi-wash { 0%,100% { opacity: 0.02; } 50% { opacity: 0.6; } }

  .vi-hud {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 0.6rem 1.2rem;
    display: flex; justify-content: space-between; align-items: baseline;
    z-index: 9; font-size: clamp(16px, 2.6vmin, 24px);
    text-shadow: 0 0 8px rgba(51,255,102,0.45);
  }
  .vi-status { color: var(--fg); }
  .vi-status::after { content: '█'; animation: vi-blink 0.9s steps(1) infinite; margin-left: 2px; }
  @keyframes vi-blink { 50% { opacity: 0; } }
  .vi-skip { color: var(--fg-dim); cursor: pointer; text-decoration: none; }
  .vi-skip:hover { color: var(--accent); text-decoration: none; }

  .vi-boot {
    position: absolute; inset: 0; z-index: 20;
    background: var(--bg);
    padding: clamp(1rem, 6vmin, 4rem);
    font-size: clamp(17px, 3vmin, 28px);
    white-space: pre-wrap; line-height: 1.45;
    text-shadow: 0 0 8px rgba(51,255,102,0.5);
    transition: opacity 0.7s ease;
    color: var(--fg);
  }
  .vi-boot.vi-gone { opacity: 0; pointer-events: none; }

  /* The site's scanlines (body.crt) sit below this overlay, so it brings its own. */
  .vi-crt { position: absolute; inset: 0; pointer-events: none; z-index: 30; }
  .vi-crt::before {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(to bottom,
      rgba(0,0,0,0) 0, rgba(0,0,0,0) 2px, rgba(0,0,0,0.18) 3px);
  }
  .vi-crt::after {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, transparent 55%, rgba(0,0,0,0.55) 100%);
  }
</style>
<script>
  import { buildDoor } from '../lib/vault-door';

  // No-ops when the overlay isn't on the page (repeat visit: server rendered nothing).
  const root = document.getElementById('vault-intro');

  if (root) {
    const boot = document.getElementById('vi-boot')!;
    const status = document.getElementById('vi-status')!;
    const title = root.dataset.title ?? '';
    const vault = root.dataset.vault ?? '94';
    const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
    let finished = false;

    const copyright = document.getElementById('vi-copyright');
    if (copyright) {
      copyright.textContent =
        `COPYRIGHT 1994-${new Date().getFullYear()} ${title.toUpperCase()}`;
    }

    const BOOT_LINES = [
      `${title.toUpperCase()} TERMLINK PROTOCOL`,
      'VISITOR CREDENTIALS .......... ACCEPTED',
      '',
      `> OVERSEER OVERRIDE: CYCLE DOOR — VAULT ${vault}`,
    ];

    const rememberSeen = () => {
      // One year; SameSite=Lax is fine for a first-party "already played" flag.
      document.cookie = 'gregco-vault-door=1; path=/; max-age=31536000; SameSite=Lax';
    };

    const cleanup = () => {
      if (finished) return;
      finished = true;
      root.classList.add('vi-leave');
      setTimeout(() => root.remove(), 950);
    };

    // Fail-safe. The overlay is opaque and covers the whole viewport, so if the
    // animation ever throws or stalls — e.g. a browser (Brave with strict
    // shields/fingerprinting) breaks a DOM/SVG call mid-sequence — the site
    // would be stuck blank with no way out. forceReveal tears it down instantly.
    const forceReveal = () => {
      if (finished) return;
      finished = true;
      try { root.remove(); } catch { /* already gone */ }
    };

    async function typeBoot() {
      for (const line of BOOT_LINES) {
        for (const ch of line) {
          if (finished) return;
          boot.textContent += ch;
          await sleep(ch === ' ' ? 3 : 7);
        }
        boot.textContent += '\n';
        await sleep(70);
      }
      await sleep(220);
    }

    async function play() {
      // Hard watchdog: no matter what the animation does, never keep the visitor
      // behind the opaque door longer than the whole sequence could legitimately
      // take (~8.5s) plus a buffer. If anything hangs, the site still appears.
      const failsafe = setTimeout(forceReveal, 12000);
      try {
        rememberSeen();
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          finished = true;
          root!.remove();
          return;
        }
        try {
          buildDoor(document.getElementById('vi-door') as unknown as SVGSVGElement, vault);
        } catch (err) {
          // Door art failed to build — skip it and still roll the overlay away
          // rather than trapping the visitor behind a blank screen.
          console.warn('[vault-intro] door render failed, revealing anyway', err);
        }

        await typeBoot();
        if (finished) return;
        boot.classList.add('vi-gone');
        await sleep(250);
        if (finished) return;

        status.textContent = 'VAULT DOOR CYCLE INITIATED';
        root!.classList.add('vi-alarm', 'vi-shudder');
        await sleep(900);
        if (finished) return;

        status.textContent = 'DISENGAGING PRESSURE SEAL';
        root!.classList.remove('vi-shudder');
        root!.classList.add('vi-unsealing');
        await sleep(2150);
        if (finished) return;

        status.textContent = 'RETRACTING DOOR';
        root!.classList.add('vi-rolling');
        await sleep(1950);
        if (finished) return;

        root!.classList.remove('vi-alarm');
        root!.classList.add('vi-revealed');
        status.textContent = 'DOOR OPEN — WELCOME, DWELLER';
        await sleep(1500);
        cleanup();
      } catch (err) {
        // Any uncaught failure in the sequence must still reveal the site.
        console.warn('[vault-intro] intro failed, revealing site', err);
        forceReveal();
      } finally {
        clearTimeout(failsafe);
      }
    }

    document.getElementById('vi-skip')!.addEventListener('click', (e) => {
      e.preventDefault();
      rememberSeen();
      cleanup();
    });

    // If the consent gate is up, it must stay the only pre-consent cookie
    // decision — hold the intro (boot screen showing) until the gate is gone.
    const gate = document.getElementById('consent-gate');
    if (gate) {
      const watcher = new MutationObserver(() => {
        if (!document.getElementById('consent-gate')) {
          watcher.disconnect();
          play();
        }
      });
      watcher.observe(document.body, { childList: true, subtree: true });
    } else {
      play();
    }
  }
</script>
