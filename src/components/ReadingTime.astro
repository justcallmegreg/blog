---
// Reading-time badge shown next to a post title. SSR renders the final value
// (no-JS safe); on the client the minutes climb 0 -> N like a dosimeter, firing
// throttled `ui:geiger` ticks through ClickSound (so it respects the mute
// toggle) and pulsing on each step. Reduced motion shows the final value at
// once. Hovering replays the climb.
interface Props {
  minutes: number;
}
const { minutes } = Astro.props;
---
{minutes > 0 && (
  <span
    class="read-time"
    data-read-minutes={minutes}
    role="img"
    aria-label={`${minutes} minute read`}
    title="Estimated reading time"
  >
    <span class="read-num">{minutes}</span> MIN
  </span>
)}

<style>
  .read-time {
    flex: none;
    align-self: center;
    border: 1px solid var(--accent);
    color: var(--accent);
    background: rgba(182, 255, 0, 0.06);
    box-shadow: inset 0 0 6px rgba(182, 255, 0, 0.15), 0 0 4px rgba(182, 255, 0, 0.25);
    padding: 0.15rem 0.55rem;
    font-size: 1rem;
    letter-spacing: 0.12em;
    line-height: 1;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    cursor: default;
    transition: box-shadow 0.1s ease-out;
  }
  .read-time.tick {
    box-shadow: inset 0 0 10px rgba(182, 255, 0, 0.5), 0 0 10px rgba(182, 255, 0, 0.6);
  }
  .read-num { font-variant-numeric: tabular-nums; }
</style>

<script>
  import { easeInValue } from '../lib/counter';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  for (const el of document.querySelectorAll<HTMLElement>('[data-read-minutes]')) {
    const value = Number(el.dataset.readMinutes || '0');
    const num = el.querySelector<HTMLElement>('.read-num');
    if (value <= 0 || !num) continue;

    let running = false;
    const climb = () => {
      if (reduce || running) return;
      running = true;
      let prev = -1;
      let lastClick = 0;
      const duration = 1000;
      num.textContent = '0';
      const step = (start: number, ts: number) => {
        const p = Math.min(1, (ts - start) / duration);
        const shown = easeInValue(value, p);
        if (shown !== prev) {
          num.textContent = String(shown);
          if (prev >= 0) {
            el.classList.add('tick');
            setTimeout(() => el.classList.remove('tick'), 90);
            const t = performance.now();
            if (t - lastClick >= 35) {
              document.dispatchEvent(new Event('ui:geiger'));
              lastClick = t;
            }
          }
          prev = shown;
        }
        if (p < 1) requestAnimationFrame((n) => step(start, n));
        else running = false;
      };
      requestAnimationFrame((ts) => step(ts, ts));
    };

    climb(); // on load
    el.addEventListener('mouseenter', climb); // replay on hover
  }
</script>
