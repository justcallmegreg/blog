---
// First-visit GDPR consent gate. Decided server-side from the `gregco-consent`
// cookie so there's no flash: if the cookie is set (or the gate is disabled in
// config) nothing renders. Otherwise a blocking backdrop with a bottom-anchored
// panel appears; ACCEPT writes the cookie (client-side) and removes the gate.
import { getConfig } from '../lib/config';

const cfg = getConfig();
const email = cfg.privacy.email;
const analytics = cfg.analytics;
const analyticsActive = analytics.enabled && analytics.matomoUrl !== '';
const accepted = Astro.cookies.get('gregco-consent')?.value === '1';
const show = cfg.privacy.consentBanner && !accepted;
---
{show && (
  <div
    id="consent-gate"
    class="consent-gate"
    role="dialog"
    aria-modal="true"
    aria-label="Data processing consent"
    data-matomo-url={analyticsActive ? analytics.matomoUrl : ''}
    data-site-id={String(analytics.siteId)}
  >
    <div class="consent-bar">
      <p class="consent-head">&gt; DATA PROCESSING NOTICE</p>
      <p class="consent-text">
        This site stores a couple of small cookies (this choice, plus a one-time flag so the
        intro animation only plays once), and processes any details you
        submit (contact or CV requests) solely to respond to you{analyticsActive ? (
          <>, plus anonymous, IP-masked analytics so we can improve the site</>
        ) : ''} — in line with GDPR. {analyticsActive ? 'No advertising.' : 'No tracking or advertising.'} You may request
        erasure of your data at any time{email ? (
          <> — contact <a href={`mailto:${email}`}>{email}</a></>
        ) : ''}. Please accept to continue.
      </p>
      <div class="consent-actions">
        <button class="contact-btn contact-approve" id="consent-accept" type="button">ACCEPT</button>
      </div>
    </div>
  </div>
)}

<style>
  .consent-gate {
    position: fixed; inset: 0; z-index: 1000;
    display: flex; align-items: flex-end; justify-content: center;
    background: rgba(11, 15, 11, 0.96);
  }
  .consent-bar {
    width: 100%; max-width: 920px;
    border-top: 1px solid var(--accent);
    background: var(--bg);
    padding: 1.25rem 1.5rem 1.5rem;
  }
  .consent-head { color: var(--accent); letter-spacing: 0.08em; margin: 0 0 0.6rem; }
  .consent-text { color: var(--fg); max-width: 80ch; margin: 0 0 1rem; }
  .consent-text a { color: var(--accent); }
  .consent-actions { display: flex; justify-content: flex-end; }
</style>

<script>
  // ACCEPT is always wired; it no-ops when the gate isn't on the page. Matomo is
  // pulled in via a guarded DYNAMIC import inside the handler (only when
  // analytics is configured) — never a static top-level import. A privacy
  // blocker such as Brave Shields blocks any request containing "matomo",
  // including our own bundled chunk; a static import would then fail to load and
  // leave the ACCEPT handler unattached, trapping the visitor behind the opaque
  // overlay. Dismissing the gate must not depend on analytics loading.
  const gate = document.getElementById('consent-gate');
  const accept = document.getElementById('consent-accept');
  if (gate && accept) {
    accept.addEventListener('click', () => {
      const url = gate.dataset.matomoUrl;
      const siteId = Number(gate.dataset.siteId ?? '1');
      // ~180 days; SameSite=Lax is fine for a first-party consent flag.
      document.cookie = 'gregco-consent=1; path=/; max-age=15552000; SameSite=Lax';
      gate.remove();
      if (url) {
        import('../lib/matomo')
          .then(({ loadMatomo }) => loadMatomo(url, siteId))
          .catch(() => {}); // analytics blocked/unavailable — consent still stands
      }
    });

    // Escape hatch for content blockers. Brave's built-in cookie-notice filter
    // (and similar ad-block cosmetic rules) hide the consent bar via CSS while
    // leaving #consent-gate in the DOM — the ACCEPT button collapses to zero size
    // and the visitor is trapped behind the opaque gate with no way to dismiss it
    // (and, since the vault-door intro waits for the gate to close, the whole site
    // goes blank). If ACCEPT isn't actually laid out shortly after load, the gate
    // can't serve its purpose, so remove it and let the site through. No consent
    // is recorded — analytics (if any) stays off, which is the privacy-safe result.
    setTimeout(() => {
      if (!document.getElementById('consent-gate')) return; // already dismissed
      const r = accept.getBoundingClientRect();
      if (r.width === 0 || r.height === 0) {
        console.warn('[consent] ACCEPT control not rendered — a content blocker hid the gate; removing it so the site stays usable');
        gate.remove();
      }
    }, 600);
  }
</script>
