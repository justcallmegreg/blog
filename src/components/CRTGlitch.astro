---
// Light, periodic CRT "beam roll": a multi-scanline band sweeps down the screen
// every `intervalSeconds` (with a little jitter). The leading edge is brightest
// and a phosphor-persistence trail fades out behind it, like a real CRT. Purely
// decorative, pointer-events:none, disabled under prefers-reduced-motion.
interface Props { intervalSeconds?: number }
const { intervalSeconds = 30 } = Astro.props;
// Persisted in the first-party `gregco-crt` cookie; read server-side so the
// toggle renders in the right state with no flash.
const crtOff = Astro.cookies.get('gregco-crt')?.value === 'off';
---
<div id="crt-glitch" data-interval={intervalSeconds} aria-hidden="true">
  <div class="crt-bar"></div>
</div>
<button id="crt-toggle" type="button" aria-label="Toggle CRT effect" aria-pressed={String(crtOff)}>{crtOff ? '[ CRT OFF ]' : '[ CRT ON ]'}</button>
<style>
  #crt-glitch { position: fixed; inset: 0; pointer-events: none; z-index: 55; overflow: hidden; }
  /* Sits directly below the [ SOUND ON/OFF ] toggle (top: 0.5rem). */
  #crt-toggle {
    position: fixed; top: 2.4rem; right: 0.5rem; z-index: 60;
    background: transparent; color: var(--fg); border: 1px solid var(--fg-dim);
    font-family: var(--font); font-size: 16px; cursor: pointer; padding: 0.1rem 0.4rem;
    /* Same fixed width as the sound toggle above it. */
    min-width: 9.5em; text-align: center;
  }
  .crt-bar {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    /* A band ~5 scanlines tall at the lit core, plus a fading phosphor trail. */
    height: 90px;
    opacity: 0;
    background-image:
      /* fine scanline stripes — a bright 1px line every 6px */
      repeating-linear-gradient(
        to bottom,
        rgba(182, 255, 0, 0) 0px,
        rgba(182, 255, 0, 0) 5px,
        rgba(182, 255, 0, 0.28) 5px,
        rgba(182, 255, 0, 0.28) 6px
      ),
      /* phosphor body: brightest at the leading edge (bottom), fading upward */
      linear-gradient(
        to top,
        rgba(255, 255, 255, 0.12) 0%,
        rgba(182, 255, 0, 0.18) 7%,
        rgba(51, 255, 102, 0.09) 45%,
        rgba(51, 255, 102, 0) 100%
      );
    /* Fade the whole band toward the top so the trail it already passed
       gradiently disappears — phosphor persistence. */
    -webkit-mask-image: linear-gradient(to top, #000 0%, #000 6%, transparent 100%);
    mask-image: linear-gradient(to top, #000 0%, #000 6%, transparent 100%);
  }
  .crt-bar.sweep { animation: crt-sweep 0.7s linear; }
  @keyframes crt-sweep {
    0%   { transform: translateY(-14vh); opacity: 0; }
    12%  { opacity: 1; }
    88%  { opacity: 1; }
    100% { transform: translateY(104vh); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    #crt-glitch, #crt-toggle { display: none; }
  }
</style>
<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    const bar = document.querySelector('#crt-glitch .crt-bar') as HTMLElement;
    const intervalMs = Number(
      (document.getElementById('crt-glitch') as HTMLElement).dataset.interval ?? 15
    ) * 1000;

    // Visitor toggle, persisted in a first-party cookie (~180 days) so it
    // survives across visits and can be read server-side.
    const setCrt = (o: boolean) =>
      (document.cookie = `gregco-crt=${o ? 'off' : 'on'}; path=/; max-age=15552000; SameSite=Lax`);
    const toggle = document.getElementById('crt-toggle') as HTMLButtonElement;
    let off = document.cookie.split('; ').includes('gregco-crt=off');
    function renderToggle() {
      toggle.textContent = off ? '[ CRT OFF ]' : '[ CRT ON ]';
      toggle.setAttribute('aria-pressed', String(off));
    }
    renderToggle();
    toggle.addEventListener('click', () => {
      off = !off;
      setCrt(off);
      renderToggle();
      if (off) bar.classList.remove('sweep'); // kill any in-flight sweep
    });

    bar.addEventListener('animationend', () => bar.classList.remove('sweep'));

    function sweep() {
      if (!off && !document.hidden) {
        bar.classList.remove('sweep');
        // force reflow so re-adding the class restarts the animation
        void bar.offsetWidth;
        bar.classList.add('sweep');
      }
    }

    function schedule() {
      // jitter ±40% so it doesn't feel metronomic
      const jitter = intervalMs * (0.6 + Math.random() * 0.8);
      setTimeout(() => {
        sweep();
        schedule();
      }, jitter);
    }
    schedule();
  }
</script>
