---
import os from 'node:os';
import '../styles/theme.css';
import ClickSound from '../components/ClickSound.astro';
import CRTGlitch from '../components/CRTGlitch.astro';
import VaultBoy from '../components/VaultBoy.astro';
import ContactOverlay from '../components/ContactOverlay.astro';
import NewsletterOverlay from '../components/NewsletterOverlay.astro';
import CvRequestOverlay from '../components/CvRequestOverlay.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Analytics from '../components/Analytics.astro';
import { getConfig } from '../lib/config';
import { VERSION } from '../lib/version';

interface Props { title?: string }
const { title } = Astro.props;
const cfg = getConfig();
const pageTitle = title ? `${title} — ${cfg.site.title}` : cfg.site.title;

// Fun "boot handshake" lines (not meant to be precise): the node this container
// resolved itself to, and where the inbound request came from.
function hostAddress(): string {
  for (const list of Object.values(os.networkInterfaces())) {
    for (const ni of list ?? []) {
      if (ni.family === 'IPv4' && !ni.internal) return ni.address;
    }
  }
  return '127.0.0.1';
}
const clean = (ip: string) => ip.replace(/^::ffff:/, '').replace(/^::1$/, '127.0.0.1');
const hostIp = hostAddress();
let clientIp = 'UNKNOWN-VAULT';
try {
  clientIp = clean(Astro.clientAddress || '') || 'UNKNOWN-VAULT';
} catch {
  clientIp = 'UNKNOWN-VAULT';
}

// Pip-Boy top tab bar. Data-driven so new tabs slot in here later.
const tabs = [
  { label: 'Blogs', href: '/' },
  { label: 'Contributions', href: '/contributions' },
  ...(cfg.about.enabled ? [{ label: 'About me', href: '/about' }] : []),
];
const path = Astro.url.pathname;
function isActive(href: string): boolean {
  // The Blogs (root) tab also covers individual post pages (/YYYY/MM/DD/...).
  if (href === '/') return path === '/' || /^\/\d{4}\//.test(path);
  return path === href || path.startsWith(href + '/');
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {cfg.site.description && <meta name="description" content={cfg.site.description} />}
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" href="/favicon-180.png" />
    <link rel="apple-touch-icon" href="/favicon-180.png" />
    <link rel="alternate" type="application/rss+xml" title={cfg.site.title} href="/rss.xml" />
  </head>
  <body class="crt">
    {cfg.effects.clickSound && <ClickSound />}
    {cfg.effects.crtGlitch && <CRTGlitch intervalSeconds={cfg.effects.crtGlitchIntervalSeconds} />}
    {cfg.effects.vaultBoy && <VaultBoy />}
    <slot name="background" />
    <header class="topbar">
      <div class="topbar-head">
        <div class="brand-block">
          <div class="brand" data-text={cfg.site.title}>&gt; <span class="brand-text" id="brand-text">{cfg.site.title}</span><span class="cursor"> </span></div>
          <div class="conn" id="conn" hidden>
            <span class="conn-badge">CONNECTED</span>
            <div class="conn-line conn-os">OS version: {VERSION}</div>
            <div class="conn-line">connected to {hostIp}</div>
            <div class="conn-line">inbound link traced to {clientIp}</div>
          </div>
        </div>
        <img class="avatar" src="/profile_picture.png" alt="" aria-hidden="true" />
        <span class="topbar-spacer" aria-hidden="true"></span>
      </div>
      <div class="topbar-row">
        <nav class="tabs" aria-label="Primary">
          {tabs.map((t) => (
            <a class:list={['tab', { 'is-active': isActive(t.href) }]} href={t.href}>{t.label}</a>
          ))}
          {cfg.contact.enabled && (
            <button type="button" class="tab contact-tab" id="contact-tab">Contact</button>
          )}
          {cfg.newsletter.enabled && (
            <button type="button" class="tab newsletter-tab" id="newsletter-tab">Newsletter</button>
          )}
        </nav>
        <div class="social">
          {cfg.social.linkedin && (
            <a class="social-link" href={`https://www.linkedin.com/in/${cfg.social.linkedin}`} aria-label="LinkedIn" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="1em" height="1em" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
              </svg>
              <span>LinkedIn</span>
            </a>
          )}
          {cfg.social.github && (
            <a class="social-link" href={`https://github.com/${cfg.social.github}`} aria-label="GitHub" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" width="1em" height="1em" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.8c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z" />
              </svg>
              <span>GitHub</span>
            </a>
          )}
          <a class="social-link" href="/rss.xml" aria-label="RSS feed">
            <svg viewBox="0 0 24 24" width="1em" height="1em" fill="currentColor" aria-hidden="true">
              <circle cx="6.18" cy="17.82" r="2.18" />
              <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83C19.56 11.4 12.6 4.44 4 4.44z" />
              <path d="M4 10.1v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z" />
            </svg>
            <span>RSS</span>
          </a>
        </div>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <script>
      // Boot effect: type the brand title out once per session. The full title
      // is server-rendered (no-JS/SEO safe); we only re-type it when animating.
      const brand = document.querySelector('.brand[data-text]') as HTMLElement | null;
      const out = document.getElementById('brand-text');
      if (brand && out) {
        const text = brand.dataset.text ?? out.textContent ?? '';
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const KEY = 'brand-typed';
        // Remove ONLY the brand's cursor once the title is fully printed (the
        // search box has its own .cursor that must keep blinking).
        const hideCursor = () => brand.querySelector('.cursor')?.remove();
        // Reveal the "connection" handshake lines once the title is printed.
        const showConn = () => document.getElementById('conn')?.removeAttribute('hidden');
        if (reduce || sessionStorage.getItem(KEY) === '1') {
          out.textContent = text;
          hideCursor();
          showConn();
        } else {
          out.textContent = '';
          let i = 0;
          const timer = setInterval(() => {
            out.textContent = text.slice(0, ++i);
            if (i >= text.length) {
              clearInterval(timer);
              sessionStorage.setItem(KEY, '1');
              hideCursor();
              showConn();
            }
          }, 45);
        }
      }
    </script>
    <script>
      // Snap the active highlight to the clicked tab immediately (the full page
      // reload also sets it server-side). The click sound fires via ClickSound.
      const tabEls = document.querySelectorAll('.tabs .tab');
      tabEls.forEach((tab) => {
        if (tab.id === 'contact-tab' || tab.id === 'newsletter-tab') return; // own handlers below
        tab.addEventListener('click', () => {
          tabEls.forEach((t) => t.classList.remove('is-active'));
          tab.classList.add('is-active');
        });
      });
      const contactTab = document.getElementById('contact-tab');
      // Contact opens a modal rather than navigating, so remember which tab was
      // active and restore it (highlight + focus) when the modal closes.
      let ctPrevActive: Element | null = null;
      contactTab?.addEventListener('click', () => {
        ctPrevActive = document.querySelector('.tabs .tab.is-active');
        tabEls.forEach((t) => t.classList.remove('is-active'));
        contactTab.classList.add('is-active');
        (window as any).openContact?.();
      });
      document.addEventListener('contact:closed', () => {
        contactTab?.classList.remove('is-active');
        if (ctPrevActive) {
          ctPrevActive.classList.add('is-active');
          (ctPrevActive as HTMLElement).focus?.();
        }
        ctPrevActive = null;
      });
      const newsletterTab = document.getElementById('newsletter-tab');
      // Newsletter opens a modal rather than navigating, so remember which tab
      // was active and restore it (highlight + focus) when the modal closes.
      let nlPrevActive: Element | null = null;
      newsletterTab?.addEventListener('click', () => {
        nlPrevActive = document.querySelector('.tabs .tab.is-active');
        tabEls.forEach((t) => t.classList.remove('is-active'));
        newsletterTab.classList.add('is-active');
        (window as any).openNewsletter?.();
      });
      document.addEventListener('newsletter:closed', () => {
        newsletterTab?.classList.remove('is-active');
        if (nlPrevActive) {
          nlPrevActive.classList.add('is-active');
          (nlPrevActive as HTMLElement).focus?.();
        }
        nlPrevActive = null;
      });
    </script>
    {cfg.contact.enabled && <ContactOverlay />}
    {cfg.newsletter.enabled && <NewsletterOverlay />}
    {cfg.about.enabled && <CvRequestOverlay />}
    <ConsentBanner />
    <Analytics />
  </body>
</html>
