---
import Terminal from '../layouts/Terminal.astro';
import MatrixRain from '../components/MatrixRain.astro';
import Search from '../components/Search.astro';
import Heatmap from '../components/Heatmap.astro';
import CounterWidget from '../components/CounterWidget.astro';
import { ensureStarted } from '../lib/store-singleton';
import { getConfig } from '../lib/config';
import { buildHeatmap } from '../lib/heatmap';
import { countInWindow } from '../lib/counter';
import type { Post } from '../lib/content-store';

const cfg = getConfig();
// Play the intro matrix rain only once per visitor: skip rendering it once the
// client has set the `gregco-matrix` cookie (set the first time it plays).
const matrixSeen = Astro.cookies.get('gregco-matrix')?.value === '1';
const store = await ensureStarted();
const posts = store.listPosts();

function ymd(d: Date): string {
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(
    d.getDate()
  ).padStart(2, '0')}`;
}
const now = new Date();
const today = ymd(now);
const yesterday = ymd(new Date(now.getFullYear(), now.getMonth(), now.getDate() - 1));
// Monday-based start of the current week.
const daysFromMonday = (now.getDay() + 6) % 7;
const startOfWeek = ymd(
  new Date(now.getFullYear(), now.getMonth(), now.getDate() - daysFromMonday)
);

// First matching bucket wins, so buckets stay mutually exclusive. Everything
// older than this week (and any future-dated posts) falls into the final
// "This month and earlier" group. The "<= today" bound keeps future-dated
// posts out of "this week".
const buckets: { label: string; match: (d: string) => boolean; posts: Post[] }[] = [
  { label: 'TODAY', match: (d) => d === today, posts: [] },
  { label: 'YESTERDAY', match: (d) => d === yesterday, posts: [] },
  { label: 'THIS WEEK', match: (d) => d >= startOfWeek && d <= today, posts: [] },
  { label: 'THIS MONTH AND EARLIER', match: () => true, posts: [] },
];
for (const p of posts) {
  (buckets.find((b) => b.match(p.date)) ?? buckets[buckets.length - 1]).posts.push(p);
}
const groups = buckets.filter((g) => g.posts.length > 0);

const dot = (date: string) => date.replace(/-/g, '.');
const searchKey = (p: Post) => `${p.title} ${p.excerpt} ${dot(p.date)}`.toLowerCase();

// Blog posting activity over the last month (one count per post on its day).
// Noon avoids a timezone shift when parsing the date-only post date.
const blogHeatmap = buildHeatmap(
  posts.map((p) => ({ createdAt: `${p.date}T12:00:00` })),
  now
);

// Posts published in the last 30 days (one per post on its date).
const postsLast30 = countInWindow(posts.map((p) => p.date), now, 30);
---
<Terminal>
  {cfg.effects.matrixRain && !matrixSeen && (
    <MatrixRain slot="background" durationSeconds={cfg.effects.matrixRainDurationSeconds} />
  )}
  {cfg.site.description && <p class="lede">{cfg.site.description}</p>}

  <div class="heat-block">
    <Heatmap
      heatmap={blogHeatmap}
      label="Blog posting activity, last month"
      unit="post"
      legend="> posts published — last month (rows: weekday, columns: ISO week)"
    />
    <CounterWidget value={postsLast30} label="POSTS // LAST 30 DAYS" />
  </div>

  <Search />

  {groups.map((g) => (
    <section class="group" data-group>
      <h2 class="group-title">{g.label}</h2>
      <ul class="post-list">
        {g.posts.map((p) => (
          <li class="entry" data-search={searchKey(p)}>
            <a class="entry-title" href={p.url}>{p.title}</a>
            {p.date && <div class="entry-meta">{dot(p.date)}</div>}
            {p.excerpt && <p class="entry-teaser">{p.excerpt}</p>}
          </li>
        ))}
      </ul>
    </section>
  ))}

  {posts.length === 0 && <p>&gt; no log entries found.</p>}
  <p id="no-results" hidden>&gt; no matching entries.</p>
</Terminal>
